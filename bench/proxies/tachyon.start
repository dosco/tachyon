#!/usr/bin/env bash
# Start tachyon with one worker per logical CPU, bound to :8080.
set -euo pipefail
cd ~/tachyon
pkill -f '^./tachyon' 2>/dev/null || true
sleep 0.3
WORKERS=$(nproc)
./tachyon -config intent/ -workers "$WORKERS" > /tmp/tachyon-bench.log 2>&1 &
# Wait until the port is open.
for _ in $(seq 1 30); do
  ss -tlnp 2>/dev/null | grep -q ':8080' && exit 0
  sleep 0.1
done
echo "tachyon did not open :8080" >&2; exit 1
